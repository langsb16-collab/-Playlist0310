{
  "name": "playlist0310-api",
  "version": "1.0.0",
  "description": "Backend API for Playlist0310",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --ip 0.0.0.0 --port 8787",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create playlist0310-db",
    "db:migrate": "wrangler d1 migrations apply playlist0310-db",
    "db:migrate:local": "wrangler d1 migrations apply playlist0310-db --local",
    "db:console": "wrangler d1 execute playlist0310-db",
    "db:console:local": "wrangler d1 execute playlist0310-db --local",
    "secret:put": "wrangler secret put"
  },
  "keywords": ["api", "cloudflare", "workers", "hono"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260310.1",
    "hono": "^4.12.6",
    "wrangler": "^4.71.0"
  }
}
